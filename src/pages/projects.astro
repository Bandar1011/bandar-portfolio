---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProjectRow from "../components/ProjectRow.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects ·Bandar Alharthi"
  description="Selected projects."
>
  <PageHeader
    title="Projects"
    kicker="Things I'm shipping right now."
  />

  <main>
    <div class="mx-auto max-w-[900px] px-6">
      <div class="rule-soft-t">
        {projects.map((p) => <ProjectRow project={p} />)}
      </div>
    </div>
  </main>
</BaseLayout>
