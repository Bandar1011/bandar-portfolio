---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ExperienceRow from "../components/ExperienceRow.astro";
import { experience } from "../data/experience";
---

<BaseLayout
  title="Experience ·Bandar Alharthi"
  description="Roles and companies."
>
  <PageHeader title="Experience" />

  <main>
    <div class="mx-auto max-w-[900px] px-6">
      <div class="rule-soft-t">
        {experience.map((e) => <ExperienceRow item={e} />)}
      </div>
    </div>
  </main>
</BaseLayout>
