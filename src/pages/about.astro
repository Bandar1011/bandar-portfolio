---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { about } from "../data/about";
---

<BaseLayout title="About Me ·Bandar Alharthi" description={about.lead}>
  <PageHeader title="About Me" kicker={about.lead} />

  <main>
    <div class="mx-auto max-w-[900px] px-6 pb-10">
      <div class="space-y-5 text-[17px] leading-relaxed">
        {about.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <dl class="mt-12 rule-soft-t">
        {
          about.facts.map((fact) => (
            <div class="py-4 rule-soft-b grid grid-cols-3 gap-4 items-baseline">
              <dt class="label col-span-1">{fact.label}</dt>
              <dd class="col-span-2 text-[15px]">{fact.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </main>
</BaseLayout>
