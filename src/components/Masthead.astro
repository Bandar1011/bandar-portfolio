---
import Crab from "./Crab.astro";
import { socials } from "../data/socials";

const age = 20;
---

<section>
  <div class="mx-auto max-w-[640px] px-6 pt-20 md:pt-28 pb-16">
    <div class="flex flex-wrap items-center gap-5 md:gap-6 mb-10">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">
        Hi, I'm Bandar.
      </h1>
      <Crab />
    </div>

    <div class="space-y-5 text-[17px] md:text-lg text-muted leading-relaxed">
      <p>
        I'm {age}, based in Tokyo and studying CS at Temple University Japan.
      </p>
      <p>
        Currently building
        <a
          href="https://resumeai.guru"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink underline underline-offset-[5px] decoration-1 hover:opacity-60 transition-opacity"
        >
          Resume AI
        </a>, an AI résumé builder. It has 1,000+ users.
      </p>
    </div>

    <!-- Compact socials -->
    <p
      class="mt-10 text-[14px] flex flex-wrap items-baseline gap-x-2 gap-y-1.5"
    >
      <span class="label mr-1">Socials</span>
      {
        socials.map((s, i) => (
          <>
            {s.href === "#" ? (
              <span class="text-muted">{s.label} (soon)</span>
            ) : (
              <a
                href={s.href}
                target={s.external ? "_blank" : undefined}
                rel={s.external ? "noopener noreferrer" : undefined}
                class="underline underline-offset-[4px] decoration-1 decoration-[color:var(--rule-soft)] hover:decoration-[color:var(--ink)] hover:opacity-100 transition-all"
              >
                {s.label}
              </a>
            )}
            {i < socials.length - 1 && <span class="text-muted">·</span>}
          </>
        ))
      }
    </p>
  </div>
</section>
