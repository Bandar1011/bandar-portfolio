---
const year = new Date().getFullYear();
---

<footer class="mt-32 md:mt-40 rule-t">
  <div class="mx-auto max-w-[1200px] px-6 md:px-10 pt-10 md:pt-12 pb-10">
    <!-- Meta row -->
    <div
      class="grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-6"
    >
      <div>
        <div class="label mb-2">© {year}</div>
        <p class="text-[14px] text-muted">All rights reserved.</p>
      </div>

      <div>
        <div class="label mb-2">Elsewhere</div>
        <ul class="space-y-1 text-[14px]">
          <li>
            <a
              class="hover:text-accent transition-colors"
              href="https://github.com/Bandar1011"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub <span class="text-muted">@Bandar1011</span> ↗
            </a>
          </li>
          <li>
            <a
              class="hover:text-accent transition-colors"
              href="https://x.com/bandar_h01"
              target="_blank"
              rel="noopener noreferrer"
            >
              X <span class="text-muted">@bandar_h01</span> ↗
            </a>
          </li>
          <li>
            <a
              class="hover:text-accent transition-colors"
              href="https://tiktok.com/@bandar_h0"
              target="_blank"
              rel="noopener noreferrer"
            >
              TikTok <span class="text-muted">@bandar_h0</span> ↗
            </a>
          </li>
        </ul>
      </div>

      <div>
        <div class="label mb-2">Contact</div>
        <a
          class="text-[14px] hover:text-accent transition-colors"
          href="mailto:support@namiai.cloud"
        >
          support@namiai.cloud
        </a>
      </div>

      <div class="md:text-right">
        <div class="label mb-2">Colophon</div>
        <p class="text-[14px] text-muted">
          Set in Inter &amp; JetBrains&nbsp;Mono.<br />
          Built with Astro.
        </p>
      </div>
    </div>
  </div>
</footer>
