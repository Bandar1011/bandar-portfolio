---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = path === "/";

const links = [
  { href: "/about", label: "About Me" },
  { href: "/projects", label: "Projects" },
  { href: "/experience", label: "Experience" },
] as const;

const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<nav class="sticky top-0 z-40 bg-paper rule-b">
  <div
    class="relative mx-auto max-w-[900px] px-6 h-[68px] md:h-[76px] flex items-center justify-center gap-6 sm:gap-8 md:gap-14"
  >
    {
      !isHome && (
        <a
          href="/"
          aria-label="Home"
          class="absolute left-4 md:left-6 flex items-center gap-2 text-[13px] font-medium hover:opacity-60 transition-opacity"
        >
          <svg
            viewBox="0 0 9 7"
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-auto"
            shape-rendering="crispEdges"
            aria-hidden="true"
          >
            <rect x="1" y="0" width="1" height="1" fill="#D97757" />
            <rect x="7" y="0" width="1" height="1" fill="#D97757" />
            <rect x="0" y="1" width="9" height="4" fill="#D97757" />
            <rect x="2" y="2" width="1" height="2" fill="#0a0a0a" />
            <rect x="6" y="2" width="1" height="2" fill="#0a0a0a" />
            <rect x="1" y="5" width="1" height="2" fill="#D97757" />
            <rect x="4" y="5" width="1" height="2" fill="#D97757" />
            <rect x="7" y="5" width="1" height="2" fill="#D97757" />
          </svg>
          <span class="hidden sm:inline">Home</span>
        </a>
      )
    }

    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "text-lg md:text-xl font-medium transition-opacity",
            isActive(l.href)
              ? "underline underline-offset-[8px] decoration-1"
              : "hover:opacity-60",
          ]}
        >
          {l.label}
        </a>
      ))
    }
  </div>
</nav>
