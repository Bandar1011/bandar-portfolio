---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/experience", label: "Experience" },
] as const;

const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<nav
  class="fixed top-0 inset-x-0 z-50 bg-[rgba(10,10,10,0.45)] border-b border-[rgba(244,244,242,0.08)]"
>
  <div
    class="mx-auto max-w-[1400px] px-6 md:px-10 h-[72px] flex items-center justify-between gap-6"
  >
    <!-- Logo: italic serif -->
    <a
      href="/"
      class="font-display italic text-xl md:text-2xl tracking-[0.02em] hover:text-accent transition-colors"
    >
      Portfolio<span class="text-accent" aria-hidden="true">.</span>
    </a>

    <!-- Center nav -->
    <div
      class="hidden md:flex items-center gap-9 label !text-[0.7rem] tracking-[0.18em]"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "transition-colors relative",
              isActive(l.href)
                ? "!text-accent"
                : "!text-ink hover:!text-accent",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <!-- Right CTA pill -->
    <a
      href="mailto:support@namiai.cloud"
      class="label !text-[0.7rem] tracking-[0.18em] !text-ink hover:!text-accent transition-colors px-5 py-2.5 rounded-full border border-[rgba(244,244,242,0.35)] hover:border-[var(--accent)]"
    >
      Contact
    </a>
  </div>

  <!-- Mobile nav row (visible only on small screens) -->
  <div
    class="md:hidden border-t border-[rgba(244,244,242,0.08)] px-6 py-2 flex items-center justify-center gap-6 label !text-[0.65rem] tracking-[0.16em]"
  >
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "transition-colors",
            isActive(l.href) ? "!text-accent" : "!text-ink hover:!text-accent",
          ]}
        >
          {l.label}
        </a>
      ))
    }
  </div>
</nav>

