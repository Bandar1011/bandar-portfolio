---
interface Props {
  title?: string;
  ruleTop?: boolean;
  id?: string;
}

const { title, ruleTop = false, id } = Astro.props;
---

<section id={id} class:list={[ruleTop && "rule-soft-t"]}>
  <div class="mx-auto max-w-[900px] px-6 py-10 md:py-14">
    {title && <h2 class="label mb-6 md:mb-8">{title}</h2>}
    <slot />
  </div>
</section>
