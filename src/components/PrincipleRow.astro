---
import type { Principle } from "../data/principles";

interface Props {
  principle: Principle;
  index: number;
}

const { principle, index } = Astro.props;
const num = `(${String(index + 1).padStart(2, "0")})`;
---

<article class="rule-soft-b py-8 md:py-10 grid grid-cols-12 gap-x-4 md:gap-x-6 items-baseline">
  <span class="label col-span-2 md:col-span-1">{num}</span>

  <h3
    class="col-span-10 md:col-span-5 text-2xl md:text-3xl lg:text-[2.25rem] leading-[1.05] tracking-[-0.02em] font-semibold"
  >
    {principle.title}
  </h3>

  <p
    class="col-span-12 md:col-span-6 text-[15px] md:text-base text-muted leading-relaxed max-w-[52ch]"
  >
    {principle.body}
  </p>
</article>
