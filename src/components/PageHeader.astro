---
interface Props {
  title: string;
  kicker?: string;
}

const { title, kicker } = Astro.props;
---

<section>
  <div class="mx-auto max-w-[900px] px-6 pt-20 md:pt-24 pb-10 md:pb-14">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">
      {title}
    </h1>
    {
      kicker && (
        <p class="mt-3 md:mt-4 text-[17px] text-muted max-w-[55ch] leading-relaxed">
          {kicker}
        </p>
      )
    }
  </div>
</section>
