---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;
const num = `(${String(index + 1).padStart(2, "0")})`;
const linkAttrs = project.external
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<a
  href={project.href}
  {...linkAttrs}
  class="group block rule-soft-b transition-colors"
>
  <article
    class="py-8 md:py-10 grid grid-cols-12 items-baseline gap-x-4 md:gap-x-6 gap-y-3"
  >
    <span class="label col-span-2 md:col-span-1">{num}</span>

    <div class="col-span-10 md:col-span-7">
      <h3
        class="text-3xl md:text-5xl lg:text-[3.5rem] leading-[0.98] tracking-[var(--tracking-tight)] font-semibold group-hover:text-accent transition-colors"
      >
        {project.title}
      </h3>
      <p
        class="mt-3 md:mt-4 text-[15px] text-muted max-w-[52ch] leading-relaxed"
      >
        {project.summary}
      </p>
    </div>

    <div class="hidden md:flex col-span-3 flex-col items-end gap-1.5">
      <span class="label">{project.kind}</span>
      <span class="label">{project.year}</span>
    </div>

    <div
      class="col-span-12 md:col-span-1 flex items-end md:items-baseline justify-end"
    >
      <span
        class="label transition-transform group-hover:translate-x-1 group-hover:text-accent inline-flex items-center gap-1"
        aria-hidden="true"
      >
        {project.external ? "Visit ↗" : "Read →"}
      </span>
    </div>
  </article>
</a>
