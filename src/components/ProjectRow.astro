---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const linkAttrs = project.external
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<a
  href={project.href}
  {...linkAttrs}
  class="group block py-6 rule-soft-b transition-opacity hover:opacity-60"
>
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="text-xl md:text-2xl font-semibold tracking-tight">
      {project.title}
      {project.external && <span class="text-muted text-base" aria-hidden="true">↗</span>}
    </h3>
    <span class="label text-right shrink-0">
      {project.kind} · {project.year}
    </span>
  </div>
  <p class="mt-2 text-[15px] text-muted max-w-[60ch] leading-relaxed">
    {project.summary}
  </p>
</a>
