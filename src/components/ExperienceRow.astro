---
import type { Experience } from "../data/experience";

interface Props {
  item: Experience;
}

const { item } = Astro.props;
const range = item.end
  ? `${item.start} →${item.end}`
  : `${item.start} →Present`;
---

<article class="py-6 rule-soft-b">
  <div class="flex items-baseline justify-between gap-4 flex-wrap">
    <h3 class="text-xl md:text-2xl font-semibold tracking-tight">
      {item.role},
      {
        item.href ? (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:opacity-60 transition-opacity"
          >
            {item.company} <span class="text-muted text-base" aria-hidden="true">↗</span>
          </a>
        ) : (
          <span>{item.company}</span>
        )
      }
    </h3>
    <span class="label shrink-0">{range}</span>
  </div>
  {
    item.summary && (
      <p class="mt-2 text-[15px] text-muted max-w-[60ch] leading-relaxed">
        {item.summary}
      </p>
    )
  }
</article>
