---
import type { Experience } from "../data/experience";

interface Props {
  item: Experience;
  index: number;
}

const { item, index } = Astro.props;
const range = item.end ? `${item.start} — ${item.end}` : `${item.start} — Present`;
const isCurrent = item.end === null;
---

<article
  class="rule-soft-b py-8 md:py-10 grid grid-cols-12 gap-x-4 md:gap-x-6 gap-y-3 items-baseline"
>
  <span class="label col-span-12 md:col-span-2 tabular-nums">
    {isCurrent && (
      <span
        class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--accent)] mr-2 align-middle"
        aria-hidden="true"
      />
    )}
    {range}
  </span>

  <div class="col-span-12 md:col-span-5">
    <h3
      class="text-2xl md:text-3xl lg:text-[2.25rem] leading-[1.08] tracking-[-0.02em] font-semibold"
    >
      {item.href ? (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-accent transition-colors inline-flex items-baseline gap-2"
        >
          {item.role}
          <span class="text-base text-muted" aria-hidden="true">↗</span>
        </a>
      ) : (
        item.role
      )}
    </h3>
    <p class="mt-1 text-base text-muted">
      {item.company}
      {item.location && (
        <>
          <span class="mx-2" aria-hidden="true">·</span>
          {item.location}
        </>
      )}
    </p>
  </div>

  <p
    class="col-span-12 md:col-span-5 text-[15px] text-muted leading-relaxed max-w-[52ch]"
  >
    {item.summary}
  </p>
</article>
